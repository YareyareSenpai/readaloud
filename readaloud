    # ── Mouse ─────────────────────────────────────────────────────────────────

    def _handle_mouse(self):
        try:
            _, mx, my, _, bstate = curses.getmouse()
        except curses.error:
            return
        H, W = self.scr.getmaxyx()

        ctrl_scroll_up   = (bstate & curses.BUTTON4_PRESSED) and (bstate & curses.BUTTON_CTRL)
        ctrl_scroll_down = (bstate & curses.BUTTON5_PRESSED) and (bstate & curses.BUTTON_CTRL)
        plain_up         = (bstate & curses.BUTTON4_PRESSED) and not (bstate & curses.BUTTON_CTRL)
        plain_down       = (bstate & curses.BUTTON5_PRESSED) and not (bstate & curses.BUTTON_CTRL)

        self._last_mouse = (f"x={mx} y={my} "
                            f"cu={bool(ctrl_scroll_up)} cd={bool(ctrl_scroll_down)} "
                            f"pu={bool(plain_up)} pd={bool(plain_down)}")

        if ctrl_scroll_up:
            zi = self.cfg.get("zoom", ZOOM_DEFAULT)
            if zi > 0:
                self.cfg["zoom"] = zi - 1
                save_config(self.cfg)
                self._invalidate()
            _kitty_font(_KITTY_INC)
            return
        if ctrl_scroll_down:
            zi = self.cfg.get("zoom", ZOOM_DEFAULT)
            if zi < len(ZOOM_LEVELS) - 1:
                self.cfg["zoom"] = zi + 1
                save_config(self.cfg)
                self._invalidate()
            _kitty_font(_KITTY_DEC)
            return

        nav_w, tl, tw, rpl, rpw, hh, fh, ch = self._layout(H, W)
        if plain_up or plain_down:
            delta = -3 if plain_up else 3
            if self.rpanel and mx >= rpl:
                bms   = self.cfg["bookmarks"].get(self._bm_key, [])
                limit = max(0, (len(get_voices_for_engine(self.cfg.get("engine","edge-tts")))
                                if self.rpanel=="voices" else len(bms)) - 1)
                self.rp_sel = max(0, min(limit, self.rp_sel + delta))
            elif self.nav_visible and mx < nav_w:
                self.ch_idx = max(0, min(len(self.chapters)-1, self.ch_idx + delta))
                self._invalidate()
            else:
                _, _, ew, _, _, _, _, _ = self._layout(H, W)
                lines = self._get_lines(ew)
                maxs  = max(0, len(lines)-5)
                self.view_scroll = max(0, min(maxs, self.view_scroll + delta))

    # ── Keyboard ──────────────────────────────────────────────────────────────

    def _handle_key(self, key):
        if key == -1: return
        try:
            self._last_key = f"{key} ({chr(key) if 32<=key<127 else '?'})"
        except Exception:
            self._last_key = str(key)

        if self.focus == "rpanel" and self.rpanel:
            if self._handle_rp_key(key):
                return

        if key in (ord('q'), ord('Q')):
            self.player.stop(); self.running = False; return

        if key == ord('?'):
            self._debug = not self._debug; return

        if key in (ord('h'), ord('H')):
            self._highlight = not self._highlight; return

        if key == ord(' '):
            if self.player.state in ("playing","paused"):
                self.player.toggle_pause()
            else:
                self._play()
            return

        if key in (curses.KEY_ENTER, 10, 13):
            self.player.stop(); self._play(); return

        if key == ord('\t'):
            order = ["chapters","text"]
            if self.rpanel: order.append("rpanel")
            cur = self.focus if self.focus in order else "chapters"
            self.focus = order[(order.index(cur)+1) % len(order)]
            return

        if key == ord('\\'):
            self.nav_visible = not self.nav_visible
            self._invalidate(); return

        if key in (ord('v'), ord('V')):
            if self.rpanel == "voices":
                self.rpanel = None
                self.focus  = "text"
            else:
                self.rpanel = "voices"
                self._rp_section = "engine"
                self._engine_sel = ENGINE_ORDER.index(self.cfg.get("engine","edge-tts"))
                self._voice_sel  = self.cfg.get("voice_index", 0)
                self.rp_scroll   = 0
                self.focus       = "rpanel"
            return

        if key in (ord('B'),):
            if self.rpanel == "bookmarks":
                self.rpanel = None
                self.focus  = "text"
            else:
                self.rpanel = "bookmarks"
                self.rp_sel = 0
                self.rp_scroll = 0
                self.focus  = "rpanel"
            return

        if key == 27:
            if self.rpanel:
                self.rpanel = None
                self.focus  = "text"
            return

        if key in (ord('n'), ord('N')):
            if self.ch_idx < len(self.chapters)-1:
                self.player.stop()
                self.ch_idx += 1
                self._invalidate(); self._play()
            return

        if key in (ord('p'), ord('P')):
            if self.ch_idx > 0:
                self.player.stop()
                self.ch_idx -= 1
                self._invalidate(); self._play()
            return

        if key in (ord('s'), ord('S')):
            was = self.player.state in ("playing","paused","loading","generating")
            self.cfg["speed_index"] = (self.cfg["speed_index"]+1) % len(SPEEDS)
            save_config(self.cfg)
            if was: self.player.stop(); self._play()
            return

        if key == ord('b'):
            bms = self.cfg["bookmarks"].setdefault(self._bm_key, [])
            if not any(bm["chapter"] == self.ch_idx for bm in bms):
                bms.append({"chapter": self.ch_idx, "note": ""})
                save_config(self.cfg)
                log.info("bookmark added ch=%d", self.ch_idx)
            return

        if key in (ord('a'), ord('A')):
            cur = self.cfg.get("align","left")
            self.cfg["align"] = ALIGN_ORDER[(ALIGN_ORDER.index(cur)+1) % len(ALIGN_ORDER)]
            save_config(self.cfg)
            self._invalidate(); return

        if key in (ord('t'), ord('T')):
            cur = self.cfg.get("theme","terminal")
            idx = THEME_ORDER.index(cur) if cur in THEME_ORDER else 0
            self.cfg["theme"] = THEME_ORDER[(idx+1) % len(THEME_ORDER)]
            save_config(self.cfg)
            self._setup_colors(); return

        if key in (ord('z'), ord('Z')):
            self._autoscroll = not self._autoscroll; return

        if key in (ord('g'), ord('G')):
            self._goto_chapter(); return

        # Arrow keys
        if self.focus == "chapters":
            if key == curses.KEY_UP and self.ch_idx > 0:
                self.ch_idx -= 1; self._invalidate()
            elif key == curses.KEY_DOWN and self.ch_idx < len(self.chapters)-1:
                self.ch_idx += 1; self._invalidate()
        elif self.focus == "rpanel" and self.rpanel:
            self._handle_rp_key(key)
        else:
            H, W = self.scr.getmaxyx()
            _, tl, tw, _, _, _, _, _ = self._layout(H, W)
            zm  = ZOOM_LEVELS[self.cfg.get("zoom", ZOOM_DEFAULT)]
            ew  = max(8, tw - zm*2)
            lines = self._get_lines(ew)
            maxs  = max(0, len(lines)-5)
            if key == curses.KEY_UP:
                self.view_scroll = max(0, self.view_scroll-1)
            elif key == curses.KEY_DOWN:
                self.view_scroll = min(maxs, self.view_scroll+1)
            elif key == curses.KEY_PPAGE:
                self.view_scroll = max(0, self.view_scroll-20)
            elif key == curses.KEY_NPAGE:
                self.view_scroll = min(maxs, self.view_scroll+20)

    def _handle_rp_key(self, key) -> bool:
        """Handle key when right panel is focused. Returns True if consumed."""
        if key == 27:
            self.rpanel = None; self.focus = "text"; return True

        if self.rpanel == "voices":
            num_engines = len(ENGINE_ORDER)

            if self._rp_section == "engine":
                if key == curses.KEY_UP:
                    self._engine_sel = max(0, self._engine_sel - 1); return True
                if key == curses.KEY_DOWN:
                    self._engine_sel = min(num_engines-1, self._engine_sel + 1); return True
                if key == ord('\t') or key == curses.KEY_RIGHT:
                    # Switch to voice sub-section
                    self._rp_section = "voice"
                    self._voice_sel  = self.cfg.get("voice_index", 0)
                    self.rp_scroll   = 0
                    return True
                if key in (curses.KEY_ENTER, 10, 13):
                    # Select engine
                    eng = ENGINE_ORDER[self._engine_sel]
                    if self._mgr.is_available(eng):
                        was = self.player.state in ("playing","paused","loading","generating")
                        self.cfg["engine"]      = eng
                        self.cfg["voice_index"] = 0
                        self._voice_sel         = 0
                        self.rp_scroll          = 0
                        save_config(self.cfg)
                        log.info("engine changed to %s", eng)
                        if was: self.player.stop(); self._play()
                    return True

            elif self._rp_section == "voice":
                eng_for_voices = ENGINE_ORDER[self._engine_sel]
                voices         = get_voices_for_engine(eng_for_voices)
                if key == curses.KEY_UP:
                    self._voice_sel = max(0, self._voice_sel - 1); return True
                if key == curses.KEY_DOWN:
                    self._voice_sel = min(max(0,len(voices)-1), self._voice_sel + 1); return True
                if key == ord('\t') or key == curses.KEY_LEFT:
                    # Switch back to engine section
                    self._rp_section = "engine"; return True
                if key in (curses.KEY_ENTER, 10, 13):
                    if voices and self._voice_sel < len(voices) and voices[0][3] != "":
                        was = self.player.state in ("playing","paused","loading","generating")
                        self.cfg["engine"]      = eng_for_voices
                        self.cfg["voice_index"] = self._voice_sel
                        save_config(self.cfg)
                        log.info("voice changed: engine=%s voice=%s",
                                 eng_for_voices, voices[self._voice_sel][0])
                        if was: self.player.stop(); self._play()
                    return True

        elif self.rpanel == "bookmarks":
            bms = self.cfg["bookmarks"].get(self._bm_key, [])
            if key == curses.KEY_UP:
                self.rp_sel = max(0, self.rp_sel-1); return True
            if key == curses.KEY_DOWN:
                self.rp_sel = min(max(0,len(bms)-1), self.rp_sel+1); return True
            if key in (curses.KEY_ENTER, 10, 13):
                if bms and self.rp_sel < len(bms):
                    target = bms[self.rp_sel]["chapter"]
                    self.player.stop()
                    self.ch_idx = target
                    self._invalidate()
                    self.rpanel = None; self.focus = "text"
                    self._play()
                return True
            if key in (ord('d'), ord('D')):
                if bms and self.rp_sel < len(bms):
                    bms.pop(self.rp_sel)
                    self.rp_sel = max(0, self.rp_sel-1)
                    self.cfg["bookmarks"][self._bm_key] = bms
                    save_config(self.cfg)
                    log.info("bookmark deleted idx=%d", self.rp_sel)
                return True

        return False

    # ── Goto chapter inline prompt ────────────────────────────────────────────

    def _goto_chapter(self):
        H, W = self.scr.getmaxyx()
        curses.curs_set(1)
        prompt = f" Go to chapter (1–{len(self.chapters)}): "
        self._sa(H-2, 0, " "*(W-1), self._cp("ftr"))
        self._sa(H-2, 0, prompt, self._cp("ftr", bold=True))
        self.scr.refresh()
        buf = ""
        while True:
            k = self.scr.getch()
            if k in (curses.KEY_ENTER, 10, 13): break
            elif k == 27: buf = ""; break
            elif k in (curses.KEY_BACKSPACE, 127): buf = buf[:-1]
            elif ord('0') <= k <= ord('9'): buf += chr(k)
            self._sa(H-2, len(prompt), buf.ljust(6), self._cp("ftr", bold=True))
            self.scr.refresh()
        curses.curs_set(0)
        if buf:
            try:
                n = int(buf)-1
                if 0 <= n < len(self.chapters):
                    self.player.stop(); self.ch_idx = n
                    self._invalidate(); self._play()
            except ValueError:
                pass


# ─── File picker ─────────────────────────────────────────────────────────────

def pick_file(stdscr):
    curses.curs_set(0)
    curses.start_color(); curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_WHITE, -1)
    curses.init_pair(2, curses.COLOR_CYAN,  -1)
    curses.init_pair(3, curses.COLOR_BLACK,  curses.COLOR_CYAN)
    curses.init_pair(8, curses.COLOR_WHITE,  curses.COLOR_BLUE)
    cwd, sel, scroll = Path.home(), 0, 0

    def entries(d):
        out = []
        try:
            if d != d.parent: out.append(("..", True, d.parent))
            for p in sorted(d.iterdir(), key=lambda p:(not p.is_dir(), p.name.lower())):
                if not p.name.startswith(".") and (p.is_dir() or p.suffix.lower() in (".epub",".txt")):
                    out.append((p.name, p.is_dir(), p))
        except PermissionError: pass
        return out

    elist = entries(cwd)
    while True:
        stdscr.erase()
        H, W = stdscr.getmaxyx()
        try:
            stdscr.addstr(0, 0, " "*(W-1), curses.color_pair(8)|curses.A_BOLD)
            stdscr.addstr(0, 0, f"  📖 readaloud — {cwd}"[:W-1], curses.color_pair(8)|curses.A_BOLD)
            stdscr.addstr(1, 0, "─"*(W-1), curses.color_pair(2))
        except curses.error: pass
        vis = H-5
        if sel < scroll: scroll = sel
        elif sel >= scroll+vis: scroll = sel-vis+1
        for row in range(vis):
            idx = scroll+row
            if idx >= len(elist): break
            name, is_dir, _ = elist[idx]
            pre  = "📁 " if is_dir else "📄 "
            line = f"  {pre}{name}"
            attr = (curses.color_pair(3)|curses.A_BOLD if idx==sel
                    else curses.color_pair(2) if is_dir
                    else curses.color_pair(1))
            try:
                stdscr.addstr(2+row, 0,
                    line[:W-1].ljust(W-1) if idx==sel else line[:W-1], attr)
            except curses.error: pass
        try:
            stdscr.addstr(H-2, 0, "  ↑↓:nav  Enter:open  q:quit"[:W-1], curses.color_pair(2))
        except curses.error: pass
        stdscr.refresh()
        k = stdscr.getch()
        if k == ord('q'): return None
        elif k == curses.KEY_UP:   sel = max(0, sel-1)
        elif k == curses.KEY_DOWN: sel = min(len(elist)-1, sel+1)
        elif k in (curses.KEY_ENTER, 10, 13) and elist:
            name, is_dir, path = elist[sel]
            if is_dir: cwd=path; elist=entries(cwd); sel=scroll=0
            else: return str(path)


# ─── Main ─────────────────────────────────────────────────────────────────────

def main():
    check_deps()
    cfg = load_config()

    # Initialise the backend manager early so scan happens before curses starts
    mgr = get_manager()
    log.info("Available engines: %s", mgr.available_engines())

    # Ensure configured engine is actually available; fall back to edge-tts
    if not mgr.is_available(cfg.get("engine", "edge-tts")):
        available = mgr.available_engines()
        cfg["engine"] = available[0] if available else "edge-tts"
        log.warning("Configured engine unavailable, using: %s", cfg["engine"])

    start_debug = "--debug" in sys.argv
    args = [a for a in sys.argv[1:] if not a.startswith("--")]

    if args:
        filepath = args[0]
    else:
        filepath = curses.wrapper(pick_file)
        if not filepath:
            print("No file selected."); sys.exit(0)

    if not os.path.exists(filepath):
        print(f"File not found: {filepath}"); sys.exit(1)

    ext = Path(filepath).suffix.lower()
    print(f"Parsing {Path(filepath).name}…", end="", flush=True)
    try:
        if ext == ".epub":   chapters = parse_epub(filepath)
        elif ext == ".txt":  chapters = parse_txt(filepath)
        else: print(f"\nUnsupported: {ext}"); sys.exit(1)
    except Exception as e:
        print(f"\nParse error: {e}")
        log.exception("parse error")
        sys.exit(1)

    if not chapters:
        print("\nNo readable chapters found."); sys.exit(1)
    print(f" {len(chapters)} chapters.")
    cfg["last_file"] = filepath
    save_config(cfg)
    log.info("starting TUI: %s  %d chapters  debug=%s", filepath, len(chapters), start_debug)

    def _run(s):
        TUI(s, chapters, filepath, cfg, start_debug=start_debug).run()

    curses.wrapper(_run)

if __name__ == "__main__":
    main()
