def check_deps():
    missing = []
    try:
        import ebooklib
    except ImportError:
        missing.append("ebooklib  →  pip install --break-system-packages ebooklib")
    if not shutil.which("ffplay"):
        missing.append("ffplay    →  sudo pacman -S ffmpeg")
    try:
        r = subprocess.run(["pipx", "run", "edge-tts", "--version"],
                           capture_output=True, timeout=30)
        if r.returncode != 0:
            missing.append("edge-tts  →  pipx install edge-tts")
    except (FileNotFoundError, subprocess.TimeoutExpired):
        missing.append("edge-tts  →  pipx install edge-tts  (pacman -S python-pipx)")
    if missing:
        print("\033[1;31m✗ Missing dependencies:\033[0m")
        for m in missing:
            print(f"  {m}")
        sys.exit(1)

# ─── EPUB / TXT parsing ───────────────────────────────────────────────────────

class _HTMLStripper(HTMLParser):
    def __init__(self):
        super().__init__()
        self._parts, self._skip = [], False
    def handle_starttag(self, tag, attrs):
        if tag in ("script", "style"):
            self._skip = True
        if tag in ("p","h1","h2","h3","h4","li","br","div"):
            self._parts.append("\n")
    def handle_endtag(self, tag):
        if tag in ("script","style"):
            self._skip = False
    def handle_data(self, data):
        if not self._skip:
            self._parts.append(data)
    def get_text(self):
        return re.sub(r'\n{3,}', '\n\n', "".join(self._parts)).strip()

def _html_to_text(html_bytes):
    p = _HTMLStripper()
    try:
        p.feed(html_bytes.decode("utf-8", errors="replace"))
    except Exception:
        pass
    return p.get_text()

def parse_epub(path):
    from ebooklib import epub, ITEM_DOCUMENT
    book  = epub.read_epub(path, options={"ignore_ncx": False})
    spine = [item_id for item_id, _ in book.spine]
    out   = []
    for iid in spine:
        item = book.get_item_with_id(iid)
        if item is None or item.get_type() != ITEM_DOCUMENT:
            continue
        text = _html_to_text(item.get_content())
        if len(text.strip()) < 80:
            continue
        title = item.get_name().replace("/", " › ")
        m = re.search(r'^\s*(.{3,80})', text)
        if m:
            fl = m.group(1).strip()
            if len(fl) < 80:
                title = fl
        out.append((title, text))
    return out

def parse_txt(path):
    text   = Path(path).read_text(errors="replace")
    chunks = re.split(r'\n{3,}|(?m)^(Chapter\s+\w+.*)', text)
    out, buf, n = [], [], 1
    for chunk in chunks:
        if chunk is None:
            continue
        buf.append(chunk)
        if len("\n".join(buf)) > 8000:
            out.append((f"Part {n}", "\n".join(buf).strip()))
            buf, n = [], n + 1
    if buf:
        out.append((f"Part {n}", "\n".join(buf).strip()))
    return [(t, c) for t, c in out if len(c.strip()) > 80]

