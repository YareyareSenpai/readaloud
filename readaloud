# ─── Voice helpers ────────────────────────────────────────────────────────────

def _piper_voices() -> list:
    """Scan MODELS_DIR for .onnx files and return as voice tuples."""
    voices = []
    try:
        for f in sorted(MODELS_DIR.glob("*.onnx")):
            name = f.stem
            voices.append((name, "??", "?", name))
    except Exception:
        pass
    return voices

def get_voices_for_engine(engine: str) -> list:
    if engine == "piper":
        v = _piper_voices()
        return v if v else [("(no models)", "", "", "")]
    if engine == "f5-tts":
        ref = VOICES_DIR / "ref.wav"
        label = "ref.wav ✓" if ref.exists() else "ref.wav missing"
        return [(label, "", "", "ref")]
    return ENGINE_VOICES.get(engine, [])

def current_voice_id(cfg: dict) -> str:
    """Return the voice identifier string for the active engine."""
    engine = cfg.get("engine", "edge-tts")
    voices = get_voices_for_engine(engine)
    if not voices:
        return ""
    idx = cfg.get("voice_index", 0)
    idx = min(idx, len(voices) - 1)
    return voices[idx][3]  # 4th element is the ID


# ─── Text helpers ─────────────────────────────────────────────────────────────

def split_text(text, max_chars=4500):
    sentences = re.split(r'(?<=[.!?])\s+', text)
    chunks, buf, length = [], [], 0
    for s in sentences:
        if length + len(s) > max_chars and buf:
            chunks.append(" ".join(buf))
            buf, length = [], 0
        buf.append(s)
        length += len(s) + 1
    if buf:
        chunks.append(" ".join(buf))
    return [c for c in chunks if c.strip()]

def wrap_text(text, width, align):
    lines = []
    for para in text.split("\n"):
        para = para.strip()
        if not para:
            lines.append(""); continue
        while len(para) > width:
            cut = para.rfind(" ", 0, width)
            if cut == -1: cut = width
            lines.append(para[:cut])
            para = para[cut:].lstrip()
        lines.append(para)
    if align == "right":
        return [l.rjust(width) if l else "" for l in lines]
    if align == "center":
        return [l.center(width) if l else "" for l in lines]
    return lines


# ─── Player ───────────────────────────────────────────────────────────────────

class Player:
    def __init__(self):
        self.state         = "idle"
        self.chunk_idx     = 0
        self.total_chunks  = 0
        self.error_msg     = ""
        self.est_char_pos  = 0
        self.play_start_ts = 0.0
        self.chapter_len   = 0
        self._chars_per_sec = 11.67
        self._proc         = None
        self._thread       = None
        self._stop_evt     = threading.Event()
        self._pause_evt    = threading.Event()
        self._pause_ts     = 0.0
        self._paused_total = 0.0
        self.on_done       = None
        # F5-TTS animation
        self._anim_idx     = 0
        self._anim_ts      = 0.0

    @property
    def anim_frame(self) -> str:
        return F5_ANIM[self._anim_idx % len(F5_ANIM)]

    def _tick_anim(self):
        now = time.time()
        if now - self._anim_ts > 0.25:
            self._anim_idx += 1
            self._anim_ts = now

    def play(self, text: str, voice: str, speed: float, engine: str):
        self.stop()
        self._stop_evt.clear()
        self._pause_evt.clear()
        self._paused_total = 0.0
        self.chapter_len   = len(text)
        self.est_char_pos  = 0
        self._thread = threading.Thread(
            target=self._run, args=(text, voice, speed, engine), daemon=True)
        self._thread.start()

    def _run(self, text: str, voice: str, speed: float, engine: str):
        mgr = get_manager()
        is_f5 = (engine == "f5-tts")
        self.state = "generating" if is_f5 else "loading"
        self.error_msg = ""
        tmpdir = tempfile.mkdtemp(prefix="readaloud_")
        log.debug("Player._run engine=%s voice=%s speed=%s len=%d", engine, voice, speed, len(text))

        chunks = split_text(text)
        self.total_chunks = len(chunks)
        audio_files = []
        ext = mgr.output_ext(engine)

        for i, chunk in enumerate(chunks):
            if self._stop_evt.is_set():
                break
            self.chunk_idx = i
            if is_f5:
                self._tick_anim()
            outfile = os.path.join(tmpdir, f"chunk_{i:04d}{ext}")
            ok = mgr.synthesize(engine, chunk, voice, speed, outfile)
            if not ok:
                self.state = "error"
                self.error_msg = f"{engine}: synthesis failed on chunk {i+1}"
                log.error(self.error_msg)
                self._cleanup(tmpdir); return
            if not os.path.exists(outfile):
                self.state = "error"
                self.error_msg = f"{engine}: no output file produced"
                log.error(self.error_msg)
                self._cleanup(tmpdir); return
            audio_files.append(outfile)
            log.debug("chunk %d/%d generated", i+1, len(chunks))

        if self._stop_evt.is_set() or not audio_files:
            self._cleanup(tmpdir)
            self.state = "idle"; return

        playlist = os.path.join(tmpdir, "playlist.txt")
        with open(playlist, "w") as f:
            for af in audio_files:
                f.write(f"file '{af}'\n")

        # Speed filter: edge-tts uses atempo; wav backends rely on atempo too
        tempo = speed
        chain = []
        while tempo > 2.0:
            chain.append("atempo=2.0"); tempo /= 2.0
        chain.append(f"atempo={tempo:.3f}")

        self.state = "playing"
        self.play_start_ts = time.time()
        self._chars_per_sec = 140 / 60 * 5 * speed
        log.debug("playback start chars_per_sec=%.1f", self._chars_per_sec)

        try:
            self._proc = subprocess.Popen(
                ["ffplay", "-nodisp", "-autoexit", "-loglevel", "quiet",
                 "-f", "concat", "-safe", "0", "-i", playlist,
                 "-af", ",".join(chain)],
                stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL)
            while self._proc.poll() is None:
                if self._stop_evt.is_set():
                    self._proc.terminate(); break
                if self._pause_evt.is_set():
                    self._proc.send_signal(signal.SIGSTOP)
                    self.state = "paused"
                    self._pause_ts = time.time()
                    while self._pause_evt.is_set() and not self._stop_evt.is_set():
                        time.sleep(0.1)
                    if not self._stop_evt.is_set():
                        self._paused_total += time.time() - self._pause_ts
                        self._proc.send_signal(signal.SIGCONT)
                        self.state = "playing"
                else:
                    elapsed = time.time() - self.play_start_ts - self._paused_total
                    self.est_char_pos = min(int(elapsed * self._chars_per_sec),
                                           self.chapter_len)
                time.sleep(0.2)
        except Exception as e:
            self.state = "error"; self.error_msg = str(e)
            log.exception("ffplay error")
            self._cleanup(tmpdir); return

        self._cleanup(tmpdir)
        if not self._stop_evt.is_set():
            self.state = "done"
            log.debug("chapter done")
            if self.on_done:
                self.on_done()

    def toggle_pause(self):
        if self.state == "playing":
            self._pause_evt.set()
        elif self.state == "paused":
            self._pause_evt.clear()

    def stop(self):
        self._stop_evt.set()
        self._pause_evt.clear()
        if self._proc and self._proc.poll() is None:
            try: self._proc.terminate()
            except: pass
        if self._thread and self._thread.is_alive():
            self._thread.join(timeout=3)
        self.state = "idle"
        self.est_char_pos = 0
        log.debug("player stopped")

    def _cleanup(self, tmpdir):
        try: shutil.rmtree(tmpdir, ignore_errors=True)
        except: pass


# ─── TUI ──────────────────────────────────────────────────────────────────────

RP_WIDTH = 28   # right panel width when visible (slightly wider for engine labels)

class TUI:
    def __init__(self, stdscr, chapters, filename, cfg, start_debug=False):
        self.scr          = stdscr
        self.chapters     = chapters
        self.filename     = Path(filename).name
        self.cfg          = cfg
        self.ch_idx       = 0
        self.ch_scroll    = 0
        self.view_scroll  = 0
        self.focus        = "chapters"
        self.nav_visible  = True
        self.rpanel       = None         # None | "voices" | "bookmarks"
        self.rp_sel       = 0
        self.rp_scroll    = 0
        # Voices panel has two sub-sections: engine row (0..3) and voice row
        self._rp_section  = "engine"     # "engine" | "voice"
        self._engine_sel  = ENGINE_ORDER.index(cfg.get("engine", "edge-tts"))
        self._voice_sel   = cfg.get("voice_index", 0)
        self.player       = Player()
        self.player.on_done = self._on_chapter_done
        self.running      = True
        self._lock        = threading.Lock()
        self._tlines      = []
        self._t_ch        = -1
        self._t_align     = None
        self._t_width     = -1
        self._autoscroll  = True
        self._highlight   = True
        self._debug       = start_debug
        self._last_key    = ""
        self._last_mouse  = ""
        self._bm_key      = self.filename
        self.cfg.setdefault("bookmarks", {}).setdefault(self._bm_key, [])
        self.cfg.setdefault("engine", "edge-tts")
        self._mgr         = get_manager()
        self._setup_colors()
        log.info("TUI init: %s  %d chapters  engine=%s",
                 self.filename, len(chapters), cfg.get("engine"))

    # ── Colors ────────────────────────────────────────────────────────────────

    def _setup_colors(self):
        curses.start_color()
        curses.use_default_colors()
        tn    = self.cfg.get("theme", "terminal")
        theme = THEMES.get(tn, THEMES["terminal"])
        use256 = (curses.COLORS >= 256
                  and curses.can_change_color()
                  and "256" in theme)
        if use256:
            cd = theme["256"]
            defs = [(16,"fg"),(17,"bg"),(18,"accent"),(19,"yellow"),
                    (20,"green"),(21,"red"),(22,"dim"),
                    (23,"hdr_bg"),(24,"hl_bg"),(25,"rp_bg")]
            for idx, key in defs:
                if key in cd:
                    try: curses.init_color(idx, *cd[key])
                    except curses.error: pass
            pairs = theme["pairs"]
        else:
            pairs = THEMES["terminal"]["pairs"]
        for name, pidx in PAIR_IDX.items():
            fg, bg = pairs.get(name, (curses.COLOR_WHITE, -1))
            try: curses.init_pair(pidx, fg, bg)
            except curses.error: pass
        log.debug("colors set theme=%s use256=%s", tn, use256)

    def _cp(self, name, bold=False, dim=False):
        a = curses.color_pair(PAIR_IDX.get(name, 1))
        if bold: a |= curses.A_BOLD
        if dim:  a |= curses.A_DIM
        return a

    # ── Callbacks ─────────────────────────────────────────────────────────────

    def _on_chapter_done(self):
        with self._lock:
            if self.ch_idx < len(self.chapters) - 1:
                self.ch_idx += 1
                self._invalidate()
                self._play()

    def _play(self):
        engine = self.cfg.get("engine", "edge-tts")
        voice  = current_voice_id(self.cfg)
        speed  = SPEEDS[self.cfg["speed_index"]]
        _, text = self.chapters[self.ch_idx]
        log.info("play ch=%d engine=%s voice=%s speed=%s", self.ch_idx, engine, voice, speed)
        self.player.play(text, voice, speed, engine)

    # ── Text helpers ──────────────────────────────────────────────────────────

    def _invalidate(self):
        self._t_ch = -1

    def _get_lines(self, width):
        align = self.cfg.get("align", "left")
        if (self._t_ch != self.ch_idx
                or self._t_align != align
                or self._t_width != width):
            _, text = self.chapters[self.ch_idx]
            self._tlines  = wrap_text(text, max(4, width - 2), align)
            self._t_ch    = self.ch_idx
            self._t_align = align
            self._t_width = width
            self.view_scroll = 0
        return self._tlines

    def _char_to_line(self, pos, lines):
        total = 0
        for i, l in enumerate(lines):
            total += len(l.strip()) + 1
            if total >= pos:
                return i
        return len(lines) - 1

    # ── Layout geometry ───────────────────────────────────────────────────────

    def _layout(self, H, W):
        header_h  = 3
        footer_h  = 6
        content_h = H - header_h - footer_h
        nav_w     = max(20, W // 4) if self.nav_visible else 0
        rp_w      = RP_WIDTH if self.rpanel else 0
        div_l     = 1 if self.nav_visible else 0
        div_r     = 1 if self.rpanel else 0
        text_left = nav_w + div_l
        text_w    = W - text_left - rp_w - div_r
        rp_left   = W - rp_w
        return nav_w, text_left, text_w, rp_left, rp_w, header_h, footer_h, content_h

    # ── Main loop ─────────────────────────────────────────────────────────────

    def run(self):
        curses.curs_set(0)
        self.scr.timeout(200)
        curses.mousemask(curses.ALL_MOUSE_EVENTS | curses.REPORT_MOUSE_POSITION)
        # Defensive overlay — show install instructions if critical deps are absent
        if SystemScanner.missing_critical:
            self._draw_missing_deps_screen()
            return
        while self.running:
            try:
                self._draw()
            except Exception:
                log.exception("draw error")
            key = self.scr.getch()
            try:
                if key == curses.KEY_MOUSE:
                    self._handle_mouse()
                else:
                    self._handle_key(key)
            except Exception:
                log.exception("key error key=%d", key)

    # ── Defensive missing-deps screen ─────────────────────────────────────────

    def _draw_missing_deps_screen(self):
        """Block the UI and display install instructions when critical deps are absent.
        Pressing any key exits cleanly rather than dropping to a shell traceback.
        """
        self.scr.clear()
        H, W = self.scr.getmaxyx()
        missing = SystemScanner.missing_critical

        title   = " readaloud — missing dependencies "
        header  = title.center(W - 1)
        try:
            self.scr.addstr(0, 0, " " * (W - 1), self._cp("err", bold=True))
            self.scr.addstr(0, 0, header[: W - 1],  self._cp("err", bold=True))
        except curses.error:
            pass

        self._sa(2, 2, "The following required components were not found:", self._cp("normal", bold=True))

        for i, msg in enumerate(missing):
            self._sa(4 + i, 4, f"✗  {msg}", self._cp("err", bold=True))

        install_hint_y = 4 + len(missing) + 2
        hints = [
            "Quick fix for Arch Linux:",
            "  sudo pacman -S ffmpeg python-pipx",
            "  pip install --break-system-packages ebooklib",
            "",
            "Or use the isolated venv installer (recommended):",
            "  ./install.sh",
            "",
            "Full install instructions: see README.md",
            "",
            "Debug log: " + str(LOG_PATH),
        ]
        for j, line in enumerate(hints):
            attr = self._cp("accent", bold=True) if line.startswith("  ") else self._cp("dim")
            self._sa(install_hint_y + j, 2, line[: W - 3], attr)

        footer = " Press any key to exit "
        self._sa(H - 2, 0, " " * (W - 1), self._cp("ftr"))
        self._sa(H - 2, max(0, (W - len(footer)) // 2), footer, self._cp("ftr", bold=True))

        self.scr.refresh()
        self.scr.timeout(-1)   # block until keypress
        self.scr.getch()

    # ── Draw dispatcher ───────────────────────────────────────────────────────

    def _draw(self):
        self.scr.erase()
        H, W = self.scr.getmaxyx()
        if H < 14 or W < 50:
            self._sa(0, 0, "Terminal too small (need 50×14)", self._cp("err", bold=True))
            self.scr.refresh(); return

        nav_w, tl, tw, rpl, rpw, hh, fh, ch = self._layout(H, W)

        self._draw_header(W)
        if self.nav_visible:
            self._draw_nav(nav_w, hh, ch)
            for r in range(ch):
                self._sa(hh+r, nav_w, BOX["v"], self._cp("accent"))
        self._draw_text(tl, tw, hh, ch)
        if self.rpanel:
            for r in range(ch):
                self._sa(hh+r, rpl-1, BOX["v"], self._cp("accent"))
            if self.rpanel == "voices":
                self._draw_rp_voices(rpl, rpw, hh, ch)
            elif self.rpanel == "bookmarks":
                self._draw_rp_bookmarks(rpl, rpw, hh, ch)
        self._draw_footer(W, H, fh)
        self._draw_float_btns(W, H, fh)
        if self._debug:
            self._draw_debug(H, W)
        self.scr.refresh()

    def _sa(self, y, x, text, attr=0):
        H, W = self.scr.getmaxyx()
        if y < 0 or y >= H or x < 0 or x >= W: return
        ml = W - x - 1
        if ml <= 0: return
        try:
            self.scr.addstr(y, x, text[:ml], attr)
        except curses.error:
            pass

    # ── Header ────────────────────────────────────────────────────────────────

    def _draw_header(self, W):
        bar = " " * (W-1)
        try: self.scr.addstr(0, 0, bar, self._cp("hdr", bold=True))
        except curses.error: pass

        tn      = THEMES.get(self.cfg.get("theme","terminal"),{}).get("name","")
        engine  = self.cfg.get("engine","edge-tts")
        elabel  = ENGINE_META.get(engine,{}).get("label", engine)
        title   = f"  📖 readaloud  ─  {self.filename}"
        nav_ind = "◀▶" if self.nav_visible else "▶▶"
        rp_ind  = ("V" if self.rpanel=="voices" else
                   "B" if self.rpanel=="bookmarks" else "·")
        right   = f"[{rp_ind}] {nav_ind}  {tn}  {self.ch_idx+1}/{len(self.chapters)}  "
        self._sa(0, 0,                              title, self._cp("hdr", bold=True))
        self._sa(0, max(len(title)+2, W-len(right)-1), right, self._cp("hdr", bold=True))
        self._sa(1, 0, BOX["h"]*(W-1), self._cp("accent"))

        vname  = current_voice_id(self.cfg) or "—"
        speed  = SPEEDS[self.cfg["speed_index"]]
        state  = self.player.state
        # F5 animation
        if state == "generating":
            self.player._tick_anim()
            icon = self.player.anim_frame
        else:
            icon = STATE_ICONS.get(state, "○")
        sc = {"playing":    self._cp("playing", bold=True),
              "loading":    self._cp("dim",     bold=True),
              "generating": self._cp("dim",     bold=True),
              "paused":     self._cp("accent",  bold=True),
              "error":      self._cp("err",     bold=True),
              "done":       self._cp("ok"),
              "idle":       self._cp("normal")}.get(state, self._cp("normal"))
        zi   = self.cfg.get("zoom", ZOOM_DEFAULT)
        albl = self.cfg.get("align","left").capitalize()
        auto = "AUTO↓" if self._autoscroll else "─────"
        hl_l = "HL" if self._highlight else "hl"
        dbg  = " DBG" if self._debug else ""
        if state == "generating":
            state_lbl = self.player.anim_frame
        else:
            state_lbl = f"{icon} {state.upper():<10}"
        sub = (f"  {state_lbl}"
               f"  [{elabel}] {vname:<14}"
               f"  Speed:{speed:.2f}×"
               f"  Align:{albl:<6}"
               f"  Z{zi+1}/{len(ZOOM_LEVELS)}"
               f"  {auto}  {hl_l}{dbg}")
        self._sa(2, 0, sub, sc)

    # ── Left nav (chapters) ───────────────────────────────────────────────────

    def _draw_nav(self, width, top, height):
        focused = self.focus == "chapters"
        lattr   = self._cp("accent", bold=True) if focused else self._cp("dim")
        bms     = self.cfg["bookmarks"].get(self._bm_key, [])
        bm_ch   = {bm["chapter"] for bm in bms}
        self._sa(top, 0, f" CHAPTERS{f'  ♥{len(bms)}' if bms else ''}", lattr)

        visible = height - 1
        if self.ch_idx < self.ch_scroll:
            self.ch_scroll = self.ch_idx
        elif self.ch_idx >= self.ch_scroll + visible:
            self.ch_scroll = self.ch_idx - visible + 1

        for row in range(visible):
            idx = self.ch_scroll + row
            y   = top + 1 + row
            if idx >= len(self.chapters): break
            title, _ = self.chapters[idx]
            is_bm    = idx in bm_ch
            maxw     = width - 5
            disp     = title[:maxw] + "…" if len(title) > maxw else title
            bmark    = "♥" if is_bm else " "

            if idx == self.ch_idx and self.player.state in ("playing","loading","paused","generating"):
                icon = STATE_ICONS.get(self.player.state, "▶")
                if self.player.state == "generating":
                    icon = "◐"
                line = f"{bmark}{icon} {disp}"
                attr = self._cp("playing", bold=True)
            elif idx == self.ch_idx and focused:
                line = f"{bmark}› {disp}".ljust(width-1)
                attr = self._cp("sel", bold=True)
            elif idx == self.ch_idx:
                line = f"{bmark}› {disp}"
                attr = self._cp("accent", bold=True)
            else:
                line = f"{bmark}{idx+1:>3}. {disp[:width-7]}"
                attr = self._cp("bm") if is_bm else self._cp("normal")

            self._sa(y, 0, line[:width-1], attr)

    # ── Text area ─────────────────────────────────────────────────────────────

    def _draw_text(self, left, width, top, height):
        if width < 8: return
        ch_title, _ = self.chapters[self.ch_idx]
        self._sa(top, left, f" ── {ch_title} "[:width-1], self._cp("accent", bold=True))

        zm     = ZOOM_LEVELS[self.cfg.get("zoom", ZOOM_DEFAULT)]
        el     = left + zm
        ew     = max(8, width - zm * 2)
        lines  = self._get_lines(ew)
        vis    = height - 1
        maxs   = max(0, len(lines) - vis)
        self.view_scroll = min(self.view_scroll, maxs)

        hl = -1
        if self._highlight and self.player.state in ("playing", "paused") and self.player.est_char_pos > 0:
            hl = self._char_to_line(self.player.est_char_pos, lines)
            if self._autoscroll:
                mg = 3
                if hl < self.view_scroll + mg:
                    self.view_scroll = max(0, hl - mg)
                elif hl >= self.view_scroll + vis - mg:
                    self.view_scroll = min(maxs, hl - vis + mg + 1)

        for row in range(vis):
            lidx = self.view_scroll + row
            y    = top + 1 + row
            if lidx >= len(lines): break
            line = lines[lidx]
            if not line: continue
            is_head = (lidx == 0 or (lidx > 0 and not lines[lidx-1].strip()))
            if lidx == hl:
                self._sa(y, el+1, line.ljust(ew-2)[:ew-2], self._cp("hl", bold=True))
            elif is_head:
                self._sa(y, el+1, line[:ew-2], self._cp("accent", bold=True))
            else:
                self._sa(y, el+1, line[:ew-2], self._cp("normal"))

        if len(lines) > vis and width > 8:
            pct = int(self.view_scroll / max(1, maxs) * 100)
            self._sa(top+1, left+width-6, f"{pct:3d}%", self._cp("dim"))

    # ── Right panel: voices (engine + voice sub-sections) ────────────────────

    def _draw_rp_voices(self, left, width, top, height):
        focused = self.focus == "rpanel"

        # Background fill
        for r in range(height):
            self._sa(top+r, left, " "*width, self._cp("rpanel"))

        # ── Header ───────────────────────────────────────────────────────────
        label = " ENGINES & VOICES" + (" ←" if focused else "")
        self._sa(top,   left, label,            self._cp("rpanel", bold=True))
        self._sa(top,   left+width-3, "Esc",   self._cp("dim"))
        self._sa(top+1, left, BOX["h"]*width,   self._cp("accent"))

        row = 2
        # ── Engine section ────────────────────────────────────────────────────
        self._sa(top+row, left, " ENGINE", self._cp("accent", bold=True))
        row += 1
        active_engine = self.cfg.get("engine", "edge-tts")

        for ei, eng_id in enumerate(ENGINE_ORDER):
            if top+row >= top+height-2: break
            meta    = ENGINE_META[eng_id]
            avail   = self._mgr.is_available(eng_id)
            is_sel  = (eng_id == active_engine)
            is_cur  = (ei == self._engine_sel)
            tick    = "✓" if is_sel else " "
            badge   = "○" if meta["type"] == "online" else "◉"
            label   = meta["label"]
            line    = f" {tick}{badge} {label:<12}"

            if not avail:
                attr = self._cp("dim")
                line = f"  {badge} {label:<12} ✗"
            elif is_cur and focused and self._rp_section == "engine":
                attr = self._cp("sel", bold=True)
            elif is_sel:
                attr = self._cp("ok", bold=True)
            elif meta["type"] == "online":
                attr = self._cp("online")
            else:
                attr = self._cp("offline")

            self._sa(top+row, left, line[:width], attr)
            row += 1

        # divider between engine and voice sections
        if top+row < top+height-2:
            self._sa(top+row, left, BOX["h"]*width, self._cp("dim"))
            row += 1

        # ── Voice section ─────────────────────────────────────────────────────
        if top+row < top+height-2:
            eng_for_voices = ENGINE_ORDER[self._engine_sel] if self._engine_sel < len(ENGINE_ORDER) else active_engine
            voices = get_voices_for_engine(eng_for_voices)

            self._sa(top+row, left,
                     f" VOICES ({eng_for_voices})"[:width],
                     self._cp("accent", bold=True))
            row += 1

            visible_voices = height - row - 2
            cur_vidx       = self.cfg.get("voice_index", 0)

            # Scroll rp_scroll in voice sub-section
            if self._rp_section == "voice":
                if self._voice_sel < self.rp_scroll:
                    self.rp_scroll = self._voice_sel
                elif self._voice_sel >= self.rp_scroll + visible_voices:
                    self.rp_scroll = self._voice_sel - visible_voices + 1
            else:
                self.rp_scroll = 0

            for vr in range(visible_voices):
                vidx = self.rp_scroll + vr
                y    = top + row + vr
                if y >= top+height-1 or vidx >= len(voices): break
                vname, vcountry, vgender, _ = voices[vidx]
                sym  = "♀" if vgender == "F" else "♂" if vgender == "M" else " "
                tick = "✓" if (vidx == cur_vidx and eng_for_voices == active_engine) else " "
                line = f" {tick}{sym} {vname:<14} {vcountry}"

                if vidx == self._voice_sel and focused and self._rp_section == "voice":
                    self._sa(y, left, line.ljust(width)[:width], self._cp("sel", bold=True))
                elif vidx == cur_vidx and eng_for_voices == active_engine:
                    self._sa(y, left, line[:width], self._cp("ok", bold=True))
                else:
                    self._sa(y, left, line[:width], self._cp("rpanel"))

        # Hint line
        hint = " ↑↓:nav  Tab:section  Enter:pick"
        self._sa(top+height-1, left, hint[:width], self._cp("dim"))

    # ── Right panel: bookmarks ────────────────────────────────────────────────

    def _draw_rp_bookmarks(self, left, width, top, height):
        focused = self.focus == "rpanel"
        hattr   = self._cp("rpanel", bold=True)
        bms     = self.cfg["bookmarks"].get(self._bm_key, [])
        for r in range(height):
            self._sa(top+r, left, " "*width, self._cp("rpanel"))
        label = f" BOOKMARKS ({len(bms)})"
        if focused:
            label += " ←"
        self._sa(top,   left, label,         hattr)
        self._sa(top,   left+width-3, "Esc", self._cp("dim"))
        self._sa(top+1, left, BOX["h"]*width, self._cp("accent"))

        if not bms:
            self._sa(top+2, left+1, "No bookmarks yet.", self._cp("dim"))
            self._sa(top+3, left+1, "Press b to add.",   self._cp("dim"))
        else:
            visible = height - 4
            if self.rp_sel < self.rp_scroll:
                self.rp_scroll = self.rp_sel
            elif self.rp_sel >= self.rp_scroll + visible:
                self.rp_scroll = self.rp_sel - visible + 1

            for row in range(visible):
                idx = self.rp_scroll + row
                y   = top + 2 + row
                if idx >= len(bms): break
                bm     = bms[idx]
                chi    = bm["chapter"]
                ctitle = self.chapters[chi][0] if chi < len(self.chapters) else "?"
                num    = f"ch{chi+1:>3}"
                disp   = ctitle[:width-8]
                line   = f" {num} {disp}"
                if idx == self.rp_sel and focused:
                    self._sa(y, left, line.ljust(width)[:width], self._cp("sel", bold=True))
                else:
                    self._sa(y, left, line[:width], self._cp("bm"))

        hint = " Enter=go  d=del  b=add"
        self._sa(top+height-1, left, hint[:width], self._cp("dim"))

    # ── Footer ────────────────────────────────────────────────────────────────

    def _draw_footer(self, W, H, fh):
        y = H - fh
        self._sa(y, 0, BOX["h"]*(W-1), self._cp("accent"))

        if self.player.state == "error" and self.player.error_msg:
            self._sa(y+1, 2, f"✗ {self.player.error_msg}"[:W//2],
                     self._cp("err", bold=True))
        elif self.player.state in ("loading", "generating"):
            total  = max(1, self.player.total_chunks)
            done   = self.player.chunk_idx
            bw     = min(28, W//3)
            filled = int(done/total*bw)
            bar    = "█"*filled + "░"*(bw-filled)
            lbl    = self.player.anim_frame if self.player.state == "generating" else "◌"
            self._sa(y+1, 2, f"{lbl} [{bar}] {done}/{total}",
                     self._cp("dim", bold=True))
        else:
            total_ch = len(self.chapters)
            bw     = min(28, W//3)
            filled = int(self.ch_idx/max(1,total_ch-1)*bw)
            bar    = "█"*filled + "░"*(bw-filled)
            self._sa(y+1, 2, f"Book [{bar}] {self.ch_idx+1}/{total_ch}",
                     self._cp("playing"))

        KEYS = [
            ("Spc", "play/pause"),  ("Enter", "play ch"),
            ("n/p",  "next/prev"),  ("\\",     "nav"),
            ("v",    "voices"),     ("B",      "bookmarks"),
            ("b",    "+bookmark"),  ("s",      "speed"),
            ("a",    "align"),      ("t",      "theme"),
            ("z",    "autoscroll"), ("h",      "highlight"),
            ("g",    "goto"),       ("C+scroll","zoom"),
        ]
        col_w   = 18
        cols    = 2
        rows_k  = (len(KEYS) + cols - 1) // cols
        box_w   = col_w * cols + 3
        box_h   = rows_k + 2

        available_rows = fh - 1
        if box_h > available_rows:
            box_h  = available_rows
            rows_k = box_h - 2

        bx = max(W//3, (W - box_w) // 2)
        by = y + 1

        if bx + box_w >= W - 14:
            bx = max(2, W - box_w - 15)

        ac = self._cp("accent")
        di = self._cp("dim")

        self._sa(by,          bx, BOX["tl"] + BOX["h"]*(box_w-2) + BOX["tr"], ac)
        self._sa(by+box_h-1,  bx, BOX["bl"] + BOX["h"]*(box_w-2) + BOX["br"], ac)
        for r in range(1, box_h-1):
            self._sa(by+r, bx,           BOX["v"], ac)
            self._sa(by+r, bx+box_w-1,   BOX["v"], ac)

        for r in range(rows_k):
            for c in range(cols):
                idx = r + c * rows_k
                if idx >= len(KEYS): continue
                k, action = KEYS[idx]
                cx = bx + 1 + c * (col_w + 1)
                ry = by + 1 + r
                if ry >= by + box_h - 1: continue
                key_lbl = f"[{k}]"
                self._sa(ry, cx,                key_lbl,               ac | curses.A_BOLD)
                self._sa(ry, cx+len(key_lbl)+1, action[:col_w-len(key_lbl)-2], di)

        btn_w  = 11
        rx     = W - btn_w - 2
        if rx > bx + box_w + 1:
            dbg_attr = self._cp("playing", bold=True) if self._debug else self._cp("accent", bold=True)
            dbg_lbl  = "? debug" if not self._debug else "? DEBUG"
            self._sa(by,          rx, BOX["tl"] + BOX["h"]*(btn_w-2) + BOX["tr"], self._cp("accent"))
            self._sa(by+1,        rx, BOX["v"], self._cp("accent"))
            self._sa(by+1,        rx+1, f" {dbg_lbl} ".center(btn_w-2)[:btn_w-2], dbg_attr)
            self._sa(by+1,        rx+btn_w-1, BOX["v"], self._cp("accent"))
            self._sa(by+2,        rx, BOX["ml"] + BOX["h"]*(btn_w-2) + BOX["mr"], self._cp("accent"))
            self._sa(by+3,        rx, BOX["v"], self._cp("accent"))
            self._sa(by+3,        rx+1, " q quit ".center(btn_w-2)[:btn_w-2], self._cp("err", bold=True))
            self._sa(by+3,        rx+btn_w-1, BOX["v"], self._cp("accent"))
            self._sa(by+4,        rx, BOX["bl"] + BOX["h"]*(btn_w-2) + BOX["br"], self._cp("accent"))

    # ── Floating prev/next ────────────────────────────────────────────────────

    def _draw_float_btns(self, W, H, fh):
        y = H - fh - 2
        if y < 4: return
        prev = " ◀ prev "
        nxt  = " next ▶ "
        x    = W - len(prev) - len(nxt) - 3
        if x < 2: return
        pa = self._cp("btn", bold=True) if self.ch_idx > 0                    else self._cp("dim")
        na = self._cp("btn", bold=True) if self.ch_idx < len(self.chapters)-1 else self._cp("dim")
        self._sa(y, x,               prev, pa)
        self._sa(y, x+len(prev)+1,   nxt,  na)

