class SystemScanner:
    """Runs once at startup; discovers which TTS backends are usable.
    Also tracks critical missing system deps so the TUI can show an
    instructions overlay instead of crashing or silently failing.
    """

    # Populated during scan(); read by TUI for defensive overlay
    missing_critical: List[str] = []

    @staticmethod
    def scan() -> Dict[str, bool]:
        status: Dict[str, bool] = {k: False for k in ENGINE_META}
        SystemScanner.missing_critical = []

        has_ffmpeg = bool(shutil.which("ffmpeg"))
        has_ffplay = bool(shutil.which("ffplay"))
        if not has_ffmpeg:
            SystemScanner.missing_critical.append(
                "ffmpeg not found — install: sudo pacman -S ffmpeg")
        if not has_ffplay:
            SystemScanner.missing_critical.append(
                "ffplay not found — install: sudo pacman -S ffmpeg")
        if not (has_ffmpeg and has_ffplay):
            log.warning("ffmpeg/ffplay missing — no audio possible")
            return status

        try:
            import ebooklib  # noqa: F401
        except ImportError:
            SystemScanner.missing_critical.append(
                "ebooklib not found — install: pip install --break-system-packages ebooklib")

        # edge-tts: pipx available or direct import
        try:
            import edge_tts  # noqa: F401
            status["edge-tts"] = True
        except ImportError:
            if shutil.which("edge-tts") or shutil.which("pipx"):
                status["edge-tts"] = True

        # kokoro — detect pykokoro (pure-Python ONNX wrapper) first, then legacy kokoro
        try:
            import pykokoro  # noqa: F401
            status["kokoro"] = True
            log.debug("Scanner: pykokoro detected")
        except ImportError:
            try:
                import kokoro  # noqa: F401  (legacy, requires Cython build)
                status["kokoro"] = True
                log.debug("Scanner: legacy kokoro detected")
            except ImportError:
                if shutil.which("kokoro"):
                    status["kokoro"] = True
                    log.debug("Scanner: kokoro CLI binary detected")

        # piper
        if shutil.which("piper"):
            status["piper"] = True
        else:
            try:
                import piper  # noqa: F401
                status["piper"] = True
            except ImportError:
                pass

        # f5-tts
        if shutil.which("f5-tts_infer-cli") or shutil.which("f5-tts"):
            status["f5-tts"] = True
        else:
            try:
                import f5_tts  # noqa: F401
                status["f5-tts"] = True
            except ImportError:
                pass

        log.info("Scanner: %s", {k: v for k, v in status.items()})
        return status


class MasterPlaybackManager:
    """Routes synthesis calls to the active backend."""

    def __init__(self):
        self.availability = SystemScanner.scan()
        self._backends: Dict[str, BaseTTSBackend] = {
            "edge-tts": EdgeTTSBackend(),
            "kokoro":   KokoroBackend(),
            "piper":    PiperBackend(),
            "f5-tts":   F5TTSBackend(),
        }

    def available_engines(self) -> List[str]:
        return [k for k in ENGINE_META if self.availability.get(k)]

    def is_available(self, engine: str) -> bool:
        return self.availability.get(engine, False)

    def output_ext(self, engine: str) -> str:
        return ENGINE_META.get(engine, {}).get("ext", ".mp3")

    def synthesize(self, engine: str, text: str, voice: str,
                   speed: float, dest_path: str) -> bool:
        if not self.is_available(engine):
            log.warning("Engine %s unavailable, falling back to edge-tts", engine)
            engine = "edge-tts"
        return self._backends[engine].generate_chunk(text, voice, speed, dest_path)


# Singleton — created once at startup
_manager: Optional[MasterPlaybackManager] = None


def get_manager() -> MasterPlaybackManager:
    global _manager
    if _manager is None:
        _manager = MasterPlaybackManager()
    return _manager


