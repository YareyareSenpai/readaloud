class BaseTTSBackend:
    """Shared interface all TTS engines implement."""
    def generate_chunk(self, text: str, voice: str, speed: float, output_path: str) -> bool:
        raise NotImplementedError


class EdgeTTSBackend(BaseTTSBackend):
    """Microsoft Edge neural TTS via pipx run edge-tts (online)."""
    def generate_chunk(self, text: str, voice: str, speed: float, output_path: str) -> bool:
        try:
            subprocess.run(
                ["pipx", "run", "edge-tts",
                 "--voice", voice, "--text", text, "--write-media", output_path],
                check=True, capture_output=True, timeout=60)
            return True
        except Exception as e:
            log.error("EdgeTTS error: %s", e)
            return False


class KokoroBackend(BaseTTSBackend):
    """Kokoro offline TTS via pykokoro — pure-Python ONNX wrapper, no Cython required.
    Install: pip install pykokoro onnxruntime soundfile
    pykokoro bypasses the legacy kokoro Cython/C-extension stack and runs inference
    directly through onnxruntime, making it compatible with Python 3.14+.
    """
    def generate_chunk(self, text: str, voice: str, speed: float, output_path: str) -> bool:
        # Primary: pykokoro library (pure-Python ONNX, Python 3.14 compatible)
        try:
            import pykokoro
            import soundfile as sf
            # pykokoro API: generate(text, voice, speed) → numpy audio array at 24000 Hz
            audio = pykokoro.generate(text, voice=voice, speed=speed)
            sf.write(output_path, audio, 24000)
            log.debug("pykokoro generated %s", output_path)
            return True
        except Exception as e:
            log.debug("pykokoro error: %s", e)
        # Fallback: legacy kokoro KPipeline (Python <3.14 environments where it compiled)
        try:
            from kokoro import KPipeline
            import soundfile as sf
            lang_code = "a" if voice.startswith("am_") or voice.startswith("af_") else "b"
            pipeline  = KPipeline(lang_code=lang_code)
            generator = pipeline(text, voice=voice, speed=speed, split_pattern=r"\n+")
            for _, _, audio in generator:
                sf.write(output_path, audio, 24000)
                return True
            return False
        except Exception as e:
            log.debug("kokoro KPipeline error: %s", e)
        # Last resort: kokoro CLI binary
        try:
            subprocess.run(
                ["kokoro", "--voice", voice, "--text", text, "--output", output_path],
                check=True, capture_output=True, timeout=120)
            return True
        except Exception as e:
            log.error("Kokoro CLI error: %s", e)
            return False


class PiperBackend(BaseTTSBackend):
    """Piper offline TTS — ultra-lightweight ONNX runtime."""
    def generate_chunk(self, text: str, voice: str, speed: float, output_path: str) -> bool:
        model_path = MODELS_DIR / f"{voice}.onnx"
        if not model_path.exists():
            log.error("Piper model not found: %s", model_path)
            return False
        try:
            proc = subprocess.Popen(
                ["piper", "--model", str(model_path), "--output_file", output_path],
                stdin=subprocess.PIPE,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL)
            proc.communicate(input=text.encode("utf-8"))
            return proc.returncode == 0
        except Exception as e:
            log.error("Piper error: %s", e)
            return False


class F5TTSBackend(BaseTTSBackend):
    """F5-TTS flow-matching voice cloner (slow on CPU, GPU recommended).
    Requires: ~/.config/readaloud/voices/ref.wav (+ optional ref.txt)
    """
    def generate_chunk(self, text: str, voice: str, speed: float, output_path: str) -> bool:
        ref_audio = VOICES_DIR / "ref.wav"
        ref_text_file = VOICES_DIR / "ref.txt"
        if not ref_audio.exists():
            log.error("F5-TTS: ref.wav not found at %s", ref_audio)
            return False
        ref_text = ""
        if ref_text_file.exists():
            ref_text = ref_text_file.read_text().strip()
        out_dir = Path(output_path).parent
        try:
            subprocess.run(
                ["f5-tts_infer-cli",
                 "--ref_audio",  str(ref_audio),
                 "--ref_text",   ref_text or "Reference voice sample.",
                 "--gen_text",   text,
                 "--output_dir", str(out_dir)],
                check=True, capture_output=True, timeout=600)
            # CLI writes out.wav — rename to expected path
            default_out = out_dir / "out.wav"
            if default_out.exists():
                default_out.rename(output_path)
                return True
            log.error("F5-TTS: out.wav not produced")
            return False
        except Exception as e:
            log.error("F5-TTS error: %s", e)
            return False


