# Right panel modes: None = hidden, "voices", "bookmarks"
RP_WIDTH = 26   # right panel width when visible

class TUI:
    def __init__(self, stdscr, chapters, filename, cfg, start_debug=False):
        self.scr          = stdscr
        self.chapters     = chapters
        self.filename     = Path(filename).name
        self.cfg          = cfg
        self.ch_idx       = 0
        self.ch_scroll    = 0
        self.view_scroll  = 0
        self.focus        = "chapters"   # "chapters" | "text" | "rpanel"
        self.nav_visible  = True
        self.rpanel       = None         # None | "voices" | "bookmarks"
        self.rp_sel       = 0
        self.rp_scroll    = 0
        self.player       = Player()
        self.player.on_done = self._on_chapter_done
        self.running      = True
        self._lock        = threading.Lock()
        # Text cache
        self._tlines      = []
        self._t_ch        = -1
        self._t_align     = None
        self._t_width     = -1
        # Autoscroll / highlight
        self._autoscroll  = True
        self._highlight   = True
        # Debug overlay
        self._debug       = start_debug
        self._last_key    = ""
        self._last_mouse  = ""
        # Bookmarks key = filename
        self._bm_key = self.filename
        self.cfg.setdefault("bookmarks", {}).setdefault(self._bm_key, [])
        self._setup_colors()
        log.info("TUI init: %s  %d chapters", self.filename, len(chapters))

    # ── Colors ────────────────────────────────────────────────────────────────

    def _setup_colors(self):
        curses.start_color()
        curses.use_default_colors()
        tn    = self.cfg.get("theme", "terminal")
        theme = THEMES.get(tn, THEMES["terminal"])
        use256 = (curses.COLORS >= 256
                  and curses.can_change_color()
                  and "256" in theme)
        if use256:
            cd = theme["256"]
            defs = [(16,"fg"),(17,"bg"),(18,"accent"),(19,"yellow"),
                    (20,"green"),(21,"red"),(22,"dim"),
                    (23,"hdr_bg"),(24,"hl_bg"),(25,"rp_bg")]
            for idx, key in defs:
                if key in cd:
                    try: curses.init_color(idx, *cd[key])
                    except curses.error: pass
            pairs = theme["pairs"]
        else:
            pairs = THEMES["terminal"]["pairs"]
        for name, pidx in PAIR_IDX.items():
            fg, bg = pairs.get(name, (curses.COLOR_WHITE, -1))
            try: curses.init_pair(pidx, fg, bg)
            except curses.error: pass
        log.debug("colors set theme=%s use256=%s", tn, use256)

    def _cp(self, name, bold=False, dim=False):
        a = curses.color_pair(PAIR_IDX.get(name, 1))
        if bold: a |= curses.A_BOLD
        if dim:  a |= curses.A_DIM
        return a

    # ── Callbacks ─────────────────────────────────────────────────────────────

    def _on_chapter_done(self):
        with self._lock:
            if self.ch_idx < len(self.chapters) - 1:
                self.ch_idx += 1
                self._invalidate()
                self._play()

    def _play(self):
        voice = VOICES[self.cfg["voice_index"]][3]
        speed = SPEEDS[self.cfg["speed_index"]]
        _, text = self.chapters[self.ch_idx]
        log.info("play ch=%d voice=%s speed=%s", self.ch_idx, voice, speed)
        self.player.play(text, voice, speed)

    # ── Text helpers ──────────────────────────────────────────────────────────

    def _invalidate(self):
        self._t_ch = -1

    def _get_lines(self, width):
        align = self.cfg.get("align", "left")
        if (self._t_ch != self.ch_idx
                or self._t_align != align
                or self._t_width != width):
            _, text = self.chapters[self.ch_idx]
            self._tlines  = wrap_text(text, max(4, width - 2), align)
            self._t_ch    = self.ch_idx
            self._t_align = align
            self._t_width = width
            self.view_scroll = 0
        return self._tlines

    def _char_to_line(self, pos, lines):
        total = 0
        for i, l in enumerate(lines):
            total += len(l.strip()) + 1
            if total >= pos:
                return i
        return len(lines) - 1

    # ── Layout geometry ───────────────────────────────────────────────────────

    def _layout(self, H, W):
        """Return (nav_w, text_left, text_w, rp_left, rp_w, header_h, footer_h, content_h)"""
        header_h  = 3
        footer_h  = 6
        content_h = H - header_h - footer_h
        nav_w     = max(20, W // 4) if self.nav_visible else 0
        rp_w      = RP_WIDTH if self.rpanel else 0
        div_l     = 1 if self.nav_visible else 0
        div_r     = 1 if self.rpanel else 0
        text_left = nav_w + div_l
        text_w    = W - text_left - rp_w - div_r
        rp_left   = W - rp_w
        return nav_w, text_left, text_w, rp_left, rp_w, header_h, footer_h, content_h

    # ── Main loop ─────────────────────────────────────────────────────────────

    def run(self):
        curses.curs_set(0)
        self.scr.timeout(200)
        curses.mousemask(curses.ALL_MOUSE_EVENTS | curses.REPORT_MOUSE_POSITION)
        while self.running:
            try:
                self._draw()
            except Exception:
                log.exception("draw error")
            key = self.scr.getch()
            try:
                if key == curses.KEY_MOUSE:
                    self._handle_mouse()
                else:
                    self._handle_key(key)
            except Exception:
                log.exception("key error key=%d", key)

    # ── Draw dispatcher ───────────────────────────────────────────────────────

    def _draw(self):
        self.scr.erase()
        H, W = self.scr.getmaxyx()
        if H < 14 or W < 50:
            self._sa(0, 0, "Terminal too small (need 50×14)", self._cp("err", bold=True))
            self.scr.refresh(); return

        nav_w, tl, tw, rpl, rpw, hh, fh, ch = self._layout(H, W)

        self._draw_header(W)
        if self.nav_visible:
            self._draw_nav(nav_w, hh, ch)
            # left divider
            for r in range(ch):
                self._sa(hh+r, nav_w, BOX["v"], self._cp("accent"))
        self._draw_text(tl, tw, hh, ch)
        if self.rpanel:
            # right divider
            for r in range(ch):
                self._sa(hh+r, rpl-1, BOX["v"], self._cp("accent"))
            if self.rpanel == "voices":
                self._draw_rp_voices(rpl, rpw, hh, ch)
            elif self.rpanel == "bookmarks":
                self._draw_rp_bookmarks(rpl, rpw, hh, ch)
        self._draw_footer(W, H, fh)
        self._draw_float_btns(W, H, fh)
        if self._debug:
            self._draw_debug(H, W)
        self.scr.refresh()

    def _sa(self, y, x, text, attr=0):
        H, W = self.scr.getmaxyx()
        if y < 0 or y >= H or x < 0 or x >= W: return
        ml = W - x - 1
        if ml <= 0: return
        try:
            self.scr.addstr(y, x, text[:ml], attr)
        except curses.error:
            pass

    # ── Header ────────────────────────────────────────────────────────────────

    def _draw_header(self, W):
        bar = " " * (W-1)
        try: self.scr.addstr(0, 0, bar, self._cp("hdr", bold=True))
        except curses.error: pass

        tn      = THEMES.get(self.cfg.get("theme","terminal"),{}).get("name","")
        title   = f"  📖 readaloud  ─  {self.filename}"
        nav_ind = "◀▶" if self.nav_visible else "▶▶"
        rp_ind  = ("V" if self.rpanel=="voices" else
                   "B" if self.rpanel=="bookmarks" else "·")
        right   = f"[{rp_ind}] {nav_ind}  {tn}  {self.ch_idx+1}/{len(self.chapters)}  "
        self._sa(0, 0,                              title, self._cp("hdr", bold=True))
        self._sa(0, max(len(title)+2, W-len(right)-1), right, self._cp("hdr", bold=True))
        self._sa(1, 0, BOX["h"]*(W-1), self._cp("accent"))

        # Status bar
        vname  = VOICES[self.cfg["voice_index"]][0]
        speed  = SPEEDS[self.cfg["speed_index"]]
        state  = self.player.state
        icon   = STATE_ICONS.get(state, "○")
        sc     = {"playing": self._cp("playing", bold=True),
                  "loading": self._cp("dim",     bold=True),
                  "paused":  self._cp("accent",  bold=True),
                  "error":   self._cp("err",     bold=True),
                  "done":    self._cp("ok"),
                  "idle":    self._cp("normal")}.get(state, self._cp("normal"))
        zi     = self.cfg.get("zoom", ZOOM_DEFAULT)
        albl   = self.cfg.get("align","left").capitalize()
        auto   = "AUTO↓" if self._autoscroll else "─────"
        hl_lbl = "HL" if self._highlight else "hl"
        dbg    = " DBG" if self._debug else ""
        sub = (f"  {icon} {state.upper():<8}"
               f"  Voice:{vname:<10}"
               f"  Speed:{speed:.2f}×"
               f"  Align:{albl:<6}"
               f"  Z{zi+1}/{len(ZOOM_LEVELS)}"
               f"  {auto}  {hl_lbl}{dbg}")
        self._sa(2, 0, sub, sc)

    # ── Left nav (chapters) ───────────────────────────────────────────────────

    def _draw_nav(self, width, top, height):
        focused = self.focus == "chapters"
        lattr   = self._cp("accent", bold=True) if focused else self._cp("dim")
        bms     = self.cfg["bookmarks"].get(self._bm_key, [])
        bm_ch   = {bm["chapter"] for bm in bms}
        self._sa(top, 0, f" CHAPTERS{f'  ♥{len(bms)}' if bms else ''}", lattr)

        visible = height - 1
        if self.ch_idx < self.ch_scroll:
            self.ch_scroll = self.ch_idx
        elif self.ch_idx >= self.ch_scroll + visible:
            self.ch_scroll = self.ch_idx - visible + 1

        for row in range(visible):
            idx = self.ch_scroll + row
            y   = top + 1 + row
            if idx >= len(self.chapters): break
            title, _ = self.chapters[idx]
            is_bm    = idx in bm_ch
            maxw     = width - 5
            disp     = title[:maxw] + "…" if len(title) > maxw else title
            bmark    = "♥" if is_bm else " "

            if idx == self.ch_idx and self.player.state in ("playing","loading","paused"):
                icon = STATE_ICONS.get(self.player.state, "▶")
                line = f"{bmark}{icon} {disp}"
                attr = self._cp("playing", bold=True)
            elif idx == self.ch_idx and focused:
                line = f"{bmark}› {disp}".ljust(width-1)
                attr = self._cp("sel", bold=True)
            elif idx == self.ch_idx:
                line = f"{bmark}› {disp}"
                attr = self._cp("accent", bold=True)
            else:
                line = f"{bmark}{idx+1:>3}. {disp[:width-7]}"
                attr = self._cp("bm") if is_bm else self._cp("normal")

            self._sa(y, 0, line[:width-1], attr)

    # ── Text area ─────────────────────────────────────────────────────────────

    def _draw_text(self, left, width, top, height):
        if width < 8: return
        ch_title, _ = self.chapters[self.ch_idx]
        self._sa(top, left, f" ── {ch_title} "[:width-1], self._cp("accent", bold=True))

        zm     = ZOOM_LEVELS[self.cfg.get("zoom", ZOOM_DEFAULT)]
        el     = left + zm
        ew     = max(8, width - zm * 2)
        lines  = self._get_lines(ew)
        vis    = height - 1
        maxs   = max(0, len(lines) - vis)
        self.view_scroll = min(self.view_scroll, maxs)

        # Highlight line from playback position
        hl = -1
        if self._highlight and self.player.state in ("playing", "paused") and self.player.est_char_pos > 0:
            hl = self._char_to_line(self.player.est_char_pos, lines)
            if self._autoscroll:
                mg = 3
                if hl < self.view_scroll + mg:
                    self.view_scroll = max(0, hl - mg)
                elif hl >= self.view_scroll + vis - mg:
                    self.view_scroll = min(maxs, hl - vis + mg + 1)

        for row in range(vis):
            lidx = self.view_scroll + row
            y    = top + 1 + row
            if lidx >= len(lines): break
            line = lines[lidx]
            if not line: continue
            is_head = (lidx == 0 or (lidx > 0 and not lines[lidx-1].strip()))
            if lidx == hl:
                self._sa(y, el+1, line.ljust(ew-2)[:ew-2], self._cp("hl", bold=True))
            elif is_head:
                self._sa(y, el+1, line[:ew-2], self._cp("accent", bold=True))
            else:
                self._sa(y, el+1, line[:ew-2], self._cp("normal"))

        if len(lines) > vis and width > 8:
            pct = int(self.view_scroll / max(1, maxs) * 100)
            self._sa(top+1, left+width-6, f"{pct:3d}%", self._cp("dim"))

    # ── Right panel: voices ───────────────────────────────────────────────────

    def _draw_rp_voices(self, left, width, top, height):
        focused = self.focus == "rpanel"
        hattr   = self._cp("rpanel", bold=True)
        # Fill background
        for r in range(height):
            self._sa(top+r, left, " "*width, self._cp("rpanel"))
        label = " VOICES"
        if focused:
            label += " ←"
        self._sa(top, left, label, hattr)
        self._sa(top, left+width-3, "Esc", self._cp("dim"))

        visible = height - 2
        cur_v   = self.cfg["voice_index"]
        # Scroll to keep rp_sel visible
        if self.rp_sel < self.rp_scroll:
            self.rp_scroll = self.rp_sel
        elif self.rp_sel >= self.rp_scroll + visible:
            self.rp_scroll = self.rp_sel - visible + 1

        self._sa(top+1, left, BOX["h"]*width, self._cp("accent"))

        for row in range(visible - 1):
            idx = self.rp_scroll + row
            y   = top + 2 + row
            if idx >= len(VOICES): break
            name, country, gender, _ = VOICES[idx]
            sym  = "♀" if gender == "F" else "♂"
            tick = "✓" if idx == cur_v else " "
            line = f" {tick}{sym} {name:<10} {country}"
            if idx == self.rp_sel and focused:
                self._sa(y, left, line.ljust(width)[:width], self._cp("sel", bold=True))
            elif idx == cur_v:
                self._sa(y, left, line[:width], self._cp("ok", bold=True))
            else:
                self._sa(y, left, line[:width], self._cp("rpanel"))

        hint = " ↑↓ Enter=pick"
        self._sa(top+height-1, left, hint[:width], self._cp("dim"))

    # ── Right panel: bookmarks ────────────────────────────────────────────────

    def _draw_rp_bookmarks(self, left, width, top, height):
        focused = self.focus == "rpanel"
        hattr   = self._cp("rpanel", bold=True)
        bms     = self.cfg["bookmarks"].get(self._bm_key, [])
        for r in range(height):
            self._sa(top+r, left, " "*width, self._cp("rpanel"))
        label = f" BOOKMARKS ({len(bms)})"
        if focused:
            label += " ←"
        self._sa(top, left, label, hattr)
        self._sa(top, left+width-3, "Esc", self._cp("dim"))
        self._sa(top+1, left, BOX["h"]*width, self._cp("accent"))

        if not bms:
            self._sa(top+2, left+1, "No bookmarks yet.", self._cp("dim"))
            self._sa(top+3, left+1, "Press b to add.", self._cp("dim"))
        else:
            visible = height - 4
            if self.rp_sel < self.rp_scroll:
                self.rp_scroll = self.rp_sel
            elif self.rp_sel >= self.rp_scroll + visible:
                self.rp_scroll = self.rp_sel - visible + 1

            for row in range(visible):
                idx = self.rp_scroll + row
                y   = top + 2 + row
                if idx >= len(bms): break
                bm     = bms[idx]
                chi    = bm["chapter"]
                ctitle = self.chapters[chi][0] if chi < len(self.chapters) else "?"
                num    = f"ch{chi+1:>3}"
                disp   = ctitle[:width-8]
                line   = f" {num} {disp}"
                if idx == self.rp_sel and focused:
                    self._sa(y, left, line.ljust(width)[:width], self._cp("sel", bold=True))
                else:
                    self._sa(y, left, line[:width], self._cp("bm"))

        hint = " Enter=go  d=del  b=add"
        self._sa(top+height-1, left, hint[:width], self._cp("dim"))

    # ── Footer ────────────────────────────────────────────────────────────────

    def _draw_footer(self, W, H, fh):
        y = H - fh
        self._sa(y, 0, BOX["h"]*(W-1), self._cp("accent"))

        # ── Row y+1: status / progress (left-anchored) ───────────────────────
        if self.player.state == "error" and self.player.error_msg:
            self._sa(y+1, 2, f"✗ {self.player.error_msg}"[:W//2],
                     self._cp("err", bold=True))
        elif self.player.state == "loading":
            total  = max(1, self.player.total_chunks)
            done   = self.player.chunk_idx
            bw     = min(28, W//3)
            filled = int(done/total*bw)
            bar    = "█"*filled + "░"*(bw-filled)
            self._sa(y+1, 2, f"◌ [{bar}] {done}/{total}",
                     self._cp("dim", bold=True))
        else:
            total_ch = len(self.chapters)
            bw     = min(28, W//3)
            filled = int(self.ch_idx/max(1,total_ch-1)*bw)
            bar    = "█"*filled + "░"*(bw-filled)
            self._sa(y+1, 2, f"Book [{bar}] {self.ch_idx+1}/{total_ch}",
                     self._cp("playing"))

        # ── Bordered key reference table (center) ────────────────────────────
        # Two columns of key:action pairs rendered inside a box
        KEYS = [
            ("Spc", "play/pause"),  ("Enter", "play ch"),
            ("n/p",  "next/prev"),  ("\\",     "nav"),
            ("v",    "voices"),     ("B",      "bookmarks"),
            ("b",    "+bookmark"),  ("s",      "speed"),
            ("a",    "align"),      ("t",      "theme"),
            ("z",    "autoscroll"), ("h",      "highlight"),
            ("g",    "goto"),       ("C+scroll","zoom"),
        ]
        col_w   = 18          # width of each column entry  "key  action"
        cols    = 2
        rows_k  = (len(KEYS) + cols - 1) // cols   # rows needed
        box_w   = col_w * cols + 3                  # inner + borders + gap
        box_h   = rows_k + 2                        # rows + top/bottom border

        # Keep box within footer height (fh-1 rows below separator)
        available_rows = fh - 1
        if box_h > available_rows:
            box_h  = available_rows
            rows_k = box_h - 2

        bx = max(W//3, (W - box_w) // 2)           # center horizontally
        by = y + 1

        # Clamp so box doesn't exceed terminal
        if bx + box_w >= W - 14:
            bx = max(2, W - box_w - 15)

        ac = self._cp("accent")
        nm = self._cp("normal")
        di = self._cp("dim")

        # Box border
        self._sa(by,          bx, BOX["tl"] + BOX["h"]*(box_w-2) + BOX["tr"], ac)
        self._sa(by+box_h-1,  bx, BOX["bl"] + BOX["h"]*(box_w-2) + BOX["br"], ac)
        for r in range(1, box_h-1):
            self._sa(by+r, bx,           BOX["v"], ac)
            self._sa(by+r, bx+box_w-1,   BOX["v"], ac)

        # Key pairs inside box
        for r in range(rows_k):
            for c in range(cols):
                idx = r + c * rows_k
                if idx >= len(KEYS): continue
                k, action = KEYS[idx]
                cx = bx + 1 + c * (col_w + 1)
                ry = by + 1 + r
                if ry >= by + box_h - 1: continue
                # Render as  [key] action
                key_lbl = f"[{k}]"
                self._sa(ry, cx,                key_lbl,               ac | curses.A_BOLD)
                self._sa(ry, cx+len(key_lbl)+1, action[:col_w-len(key_lbl)-2], di)

        # ── Right side: [? debug] and [q quit] stacked buttons ───────────────
        btn_w  = 11
        rx     = W - btn_w - 2
        if rx > bx + box_w + 1:
            # Top button: debug (highlighted if active)
            dbg_attr = self._cp("playing", bold=True) if self._debug else self._cp("accent", bold=True)
            dbg_lbl  = "? debug" if not self._debug else "? DEBUG"
            self._sa(by,          rx, BOX["tl"] + BOX["h"]*(btn_w-2) + BOX["tr"], self._cp("accent"))
            self._sa(by+1,        rx, BOX["v"], self._cp("accent"))
            self._sa(by+1,        rx+1, f" {dbg_lbl} ".center(btn_w-2)[:btn_w-2], dbg_attr)
            self._sa(by+1,        rx+btn_w-1, BOX["v"], self._cp("accent"))
            self._sa(by+2,        rx, BOX["ml"] + BOX["h"]*(btn_w-2) + BOX["mr"], self._cp("accent"))
            # Bottom button: quit
            self._sa(by+3,        rx, BOX["v"], self._cp("accent"))
            self._sa(by+3,        rx+1, " q quit ".center(btn_w-2)[:btn_w-2], self._cp("err", bold=True))
            self._sa(by+3,        rx+btn_w-1, BOX["v"], self._cp("accent"))
            self._sa(by+4,        rx, BOX["bl"] + BOX["h"]*(btn_w-2) + BOX["br"], self._cp("accent"))

    # ── Floating prev/next ────────────────────────────────────────────────────

    def _draw_float_btns(self, W, H, fh):
        y = H - fh - 2
        if y < 4: return
        prev = " ◀ prev "
        nxt  = " next ▶ "
        x    = W - len(prev) - len(nxt) - 3
        if x < 2: return
        pa = self._cp("btn", bold=True) if self.ch_idx > 0                    else self._cp("dim")
        na = self._cp("btn", bold=True) if self.ch_idx < len(self.chapters)-1 else self._cp("dim")
        self._sa(y, x,               prev, pa)
        self._sa(y, x+len(prev)+1,   nxt,  na)

    # ── Debug overlay ─────────────────────────────────────────────────────────

    def _draw_debug(self, H, W):
        p      = self.player
        bms    = self.cfg["bookmarks"].get(self._bm_key, [])
        H2, W2 = self.scr.getmaxyx()
        dh     = 14
        dy     = max(3, H2 - dh - 4)
        dw     = min(72, W2 - 4)
        dx     = max(0, (W2 - dw) // 2)

        # Background fill
        for r in range(dh):
            self._sa(dy+r, dx, " "*dw, self._cp("hdr"))
        # Border
        self._sa(dy,      dx, BOX["tl"]+BOX["h"]*(dw-2)+BOX["tr"], self._cp("playing", bold=True))
        self._sa(dy+dh-1, dx, BOX["bl"]+BOX["h"]*(dw-2)+BOX["br"], self._cp("playing", bold=True))
        for r in range(1, dh-1):
            self._sa(dy+r, dx,      BOX["v"], self._cp("playing", bold=True))
            self._sa(dy+r, dx+dw-1, BOX["v"], self._cp("playing", bold=True))
        self._sa(dy, dx+2, " DEBUG  (? to close) ", self._cp("playing", bold=True))

        rows = [
            f"  File       : {self.filename}",
            f"  Chapter    : {self.ch_idx+1}/{len(self.chapters)}  scroll={self.view_scroll}",
            f"  Player     : state={p.state}  chunk={p.chunk_idx}/{p.total_chunks}",
            f"  Playback   : est_pos={p.est_char_pos}  ch_len={p.chapter_len}  cps={p._chars_per_sec:.1f}",
            f"  Paused     : total_paused={p._paused_total:.1f}s",
            f"  Config     : voice={VOICES[self.cfg['voice_index']][0]}  "
                           f"speed={SPEEDS[self.cfg['speed_index']]}×  "
                           f"align={self.cfg.get('align')}  "
                           f"zoom={self.cfg.get('zoom')}  "
                           f"theme={self.cfg.get('theme')}",
            f"  Nav        : nav_vis={self.nav_visible}  rpanel={self.rpanel}  focus={self.focus}",
            f"  Autoscroll : {self._autoscroll}  Highlight: {self._highlight}",
            f"  Bookmarks  : {len(bms)} for this file",
            f"  Last key   : {self._last_key}",
            f"  Last mouse : {self._last_mouse}",
            f"  Log        : {LOG_PATH}",
        ]
        for i, row in enumerate(rows[:dh-2]):
            self._sa(dy+1+i, dx+1, row[:dw-2], self._cp("normal"))

    # ── Mouse ─────────────────────────────────────────────────────────────────

    def _handle_mouse(self):
        try:
            _, mx, my, _, bstate = curses.getmouse()
        except curses.error:
            return
        H, W = self.scr.getmaxyx()

        ctrl_scroll_up   = (bstate & curses.BUTTON4_PRESSED) and (bstate & curses.BUTTON_CTRL)
        ctrl_scroll_down = (bstate & curses.BUTTON5_PRESSED) and (bstate & curses.BUTTON_CTRL)
        plain_up         = (bstate & curses.BUTTON4_PRESSED) and not (bstate & curses.BUTTON_CTRL)
        plain_down       = (bstate & curses.BUTTON5_PRESSED) and not (bstate & curses.BUTTON_CTRL)

        self._last_mouse = (f"x={mx} y={my} "
                            f"cu={bool(ctrl_scroll_up)} cd={bool(ctrl_scroll_down)} "
                            f"pu={bool(plain_up)} pd={bool(plain_down)}")
        log.debug("mouse %s", self._last_mouse)

        # Ctrl+scroll → kitty font zoom
        if ctrl_scroll_up:
            zi = self.cfg.get("zoom", ZOOM_DEFAULT)
            if zi > 0:
                self.cfg["zoom"] = zi - 1
                save_config(self.cfg)
                self._invalidate()
            _kitty_font(_KITTY_INC)
            return
        if ctrl_scroll_down:
            zi = self.cfg.get("zoom", ZOOM_DEFAULT)
            if zi < len(ZOOM_LEVELS) - 1:
                self.cfg["zoom"] = zi + 1
                save_config(self.cfg)
                self._invalidate()
            _kitty_font(_KITTY_DEC)
            return

        # Plain scroll → scroll the appropriate panel
        nav_w, tl, tw, rpl, rpw, hh, fh, ch = self._layout(H, W)
        if plain_up or plain_down:
            delta = -3 if plain_up else 3
            # Which column?
            if self.rpanel and mx >= rpl:
                bms = self.cfg["bookmarks"].get(self._bm_key, [])
                limit = max(0, (len(VOICES) if self.rpanel=="voices" else len(bms)) - 1)
                self.rp_sel = max(0, min(limit, self.rp_sel + delta))
            elif self.nav_visible and mx < nav_w:
                self.ch_idx = max(0, min(len(self.chapters)-1, self.ch_idx + delta))
                self._invalidate()
            else:
                _, _, ew, _, _, _, _, _ = self._layout(H, W)
                lines = self._get_lines(ew)
                maxs  = max(0, len(lines)-5)
                self.view_scroll = max(0, min(maxs, self.view_scroll + delta))

    # ── Keyboard ──────────────────────────────────────────────────────────────

    def _handle_key(self, key):
        if key == -1: return
        try:
            self._last_key = f"{key} ({chr(key) if 32<=key<127 else '?'})"
        except Exception:
            self._last_key = str(key)

        # If right panel is focused, route there first
        if self.focus == "rpanel" and self.rpanel:
            if self._handle_rp_key(key):
                return

        # Global
        if key in (ord('q'), ord('Q')):
            self.player.stop(); self.running = False; return

        if key == ord('?'):
            self._debug = not self._debug; return

        # Highlight toggle
        if key in (ord('h'), ord('H')):
            self._highlight = not self._highlight; return

        if key == ord(' '):
            if self.player.state in ("playing","paused"):
                self.player.toggle_pause()
            else:
                self._play()
            return

        if key in (curses.KEY_ENTER, 10, 13):
            self.player.stop(); self._play(); return

        if key == ord('\t'):
            # Cycle focus: chapters → text → rpanel (if visible) → chapters
            order = ["chapters","text"]
            if self.rpanel: order.append("rpanel")
            cur = self.focus if self.focus in order else "chapters"
            self.focus = order[(order.index(cur)+1) % len(order)]
            return

        if key == ord('\\'):
            self.nav_visible = not self.nav_visible
            self._invalidate(); return

        # Toggle right panels
        if key in (ord('v'), ord('V')):
            if self.rpanel == "voices":
                self.rpanel = None
                self.focus  = "text"
            else:
                self.rpanel = "voices"
                self.rp_sel = self.cfg["voice_index"]
                self.rp_scroll = 0
                self.focus  = "rpanel"
            return

        if key in (ord('B'),):
            if self.rpanel == "bookmarks":
                self.rpanel = None
                self.focus  = "text"
            else:
                self.rpanel = "bookmarks"
                self.rp_sel = 0
                self.rp_scroll = 0
                self.focus  = "rpanel"
            return

        if key == 27:   # Esc — close right panel
            if self.rpanel:
                self.rpanel = None
                self.focus  = "text"
            return

        # Chapter nav
        if key in (ord('n'), ord('N')):
            if self.ch_idx < len(self.chapters)-1:
                self.player.stop()
                self.ch_idx += 1
                self._invalidate(); self._play()
            return

        if key in (ord('p'), ord('P')):
            if self.ch_idx > 0:
                self.player.stop()
                self.ch_idx -= 1
                self._invalidate(); self._play()
            return

        # Speed
        if key in (ord('s'), ord('S')):
            was = self.player.state in ("playing","paused","loading")
            self.cfg["speed_index"] = (self.cfg["speed_index"]+1) % len(SPEEDS)
            save_config(self.cfg)
            if was: self.player.stop(); self._play()
            return

        # Bookmark add
        if key == ord('b'):
            bms = self.cfg["bookmarks"].setdefault(self._bm_key, [])
            if not any(bm["chapter"] == self.ch_idx for bm in bms):
                bms.append({"chapter": self.ch_idx, "note": ""})
                save_config(self.cfg)
                log.info("bookmark added ch=%d", self.ch_idx)
            return

        # Align
        if key in (ord('a'), ord('A')):
            cur = self.cfg.get("align","left")
            self.cfg["align"] = ALIGN_ORDER[(ALIGN_ORDER.index(cur)+1) % len(ALIGN_ORDER)]
            save_config(self.cfg)
            self._invalidate(); return

        # Theme
        if key in (ord('t'), ord('T')):
            cur = self.cfg.get("theme","terminal")
            idx = THEME_ORDER.index(cur) if cur in THEME_ORDER else 0
            self.cfg["theme"] = THEME_ORDER[(idx+1) % len(THEME_ORDER)]
            save_config(self.cfg)
            self._setup_colors(); return

        # Autoscroll
        if key in (ord('z'), ord('Z')):
            self._autoscroll = not self._autoscroll; return

        # Goto
        if key in (ord('g'), ord('G')):
            self._goto_chapter(); return

        # Arrow keys — route by focus
        if self.focus == "chapters":
            if key == curses.KEY_UP and self.ch_idx > 0:
                self.ch_idx -= 1; self._invalidate()
            elif key == curses.KEY_DOWN and self.ch_idx < len(self.chapters)-1:
                self.ch_idx += 1; self._invalidate()
        elif self.focus == "rpanel" and self.rpanel:
            self._handle_rp_key(key)
        else:   # text
            H, W = self.scr.getmaxyx()
            _, tl, tw, _, _, _, _, _ = self._layout(H, W)
            zm  = ZOOM_LEVELS[self.cfg.get("zoom", ZOOM_DEFAULT)]
            ew  = max(8, tw - zm*2)
            lines = self._get_lines(ew)
            maxs  = max(0, len(lines)-5)
            if key == curses.KEY_UP:
                self.view_scroll = max(0, self.view_scroll-1)
            elif key == curses.KEY_DOWN:
                self.view_scroll = min(maxs, self.view_scroll+1)
            elif key == curses.KEY_PPAGE:
                self.view_scroll = max(0, self.view_scroll-20)
            elif key == curses.KEY_NPAGE:
                self.view_scroll = min(maxs, self.view_scroll+20)

    def _handle_rp_key(self, key):
        """Handle key when right panel is focused. Returns True if consumed."""
        if key == 27 or key == ord('q'):
            self.rpanel = None; self.focus = "text"; return True

        if self.rpanel == "voices":
            if key == curses.KEY_UP:
                self.rp_sel = max(0, self.rp_sel-1); return True
            if key == curses.KEY_DOWN:
                self.rp_sel = min(len(VOICES)-1, self.rp_sel+1); return True
            if key in (curses.KEY_ENTER, 10, 13):
                was = self.player.state in ("playing","paused","loading")
                self.cfg["voice_index"] = self.rp_sel
                save_config(self.cfg)
                log.info("voice changed to %s", VOICES[self.rp_sel][0])
                if was: self.player.stop(); self._play()
                return True

        elif self.rpanel == "bookmarks":
            bms = self.cfg["bookmarks"].get(self._bm_key, [])
            if key == curses.KEY_UP:
                self.rp_sel = max(0, self.rp_sel-1); return True
            if key == curses.KEY_DOWN:
                self.rp_sel = min(max(0,len(bms)-1), self.rp_sel+1); return True
            if key in (curses.KEY_ENTER, 10, 13):
                if bms and self.rp_sel < len(bms):
                    target = bms[self.rp_sel]["chapter"]
                    self.player.stop()
                    self.ch_idx = target
                    self._invalidate()
                    self.rpanel = None; self.focus = "text"
                    self._play()
                return True
            if key in (ord('d'), ord('D')):
                if bms and self.rp_sel < len(bms):
                    bms.pop(self.rp_sel)
                    self.rp_sel = max(0, self.rp_sel-1)
                    self.cfg["bookmarks"][self._bm_key] = bms
                    save_config(self.cfg)
                    log.info("bookmark deleted idx=%d", self.rp_sel)
                return True

        return False

    # ── Goto chapter inline prompt ────────────────────────────────────────────

    def _goto_chapter(self):
        H, W = self.scr.getmaxyx()
        curses.curs_set(1)
        prompt = f" Go to chapter (1–{len(self.chapters)}): "
        self._sa(H-2, 0, " "*(W-1), self._cp("ftr"))
        self._sa(H-2, 0, prompt, self._cp("ftr", bold=True))
        self.scr.refresh()
        buf = ""
        while True:
            k = self.scr.getch()
            if k in (curses.KEY_ENTER, 10, 13): break
            elif k == 27: buf = ""; break
            elif k in (curses.KEY_BACKSPACE, 127): buf = buf[:-1]
            elif ord('0') <= k <= ord('9'): buf += chr(k)
            self._sa(H-2, len(prompt), buf.ljust(6), self._cp("ftr", bold=True))
            self.scr.refresh()
        curses.curs_set(0)
        if buf:
            try:
                n = int(buf)-1
                if 0 <= n < len(self.chapters):
                    self.player.stop(); self.ch_idx = n
                    self._invalidate(); self._play()
            except ValueError:
                pass

# ─── File picker ─────────────────────────────────────────────────────────────

def pick_file(stdscr):
    curses.curs_set(0)
    curses.start_color(); curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_WHITE, -1)
    curses.init_pair(2, curses.COLOR_CYAN,  -1)
    curses.init_pair(3, curses.COLOR_BLACK,  curses.COLOR_CYAN)
    curses.init_pair(8, curses.COLOR_WHITE,  curses.COLOR_BLUE)
    cwd, sel, scroll = Path.home(), 0, 0

    def entries(d):
        out = []
        try:
            if d != d.parent: out.append(("..", True, d.parent))
            for p in sorted(d.iterdir(), key=lambda p:(not p.is_dir(), p.name.lower())):
                if not p.name.startswith(".") and (p.is_dir() or p.suffix.lower() in (".epub",".txt")):
                    out.append((p.name, p.is_dir(), p))
        except PermissionError: pass
        return out

    elist = entries(cwd)
    while True:
        stdscr.erase()
        H, W = stdscr.getmaxyx()
        try:
            stdscr.addstr(0, 0, " "*(W-1), curses.color_pair(8)|curses.A_BOLD)
            stdscr.addstr(0, 0, f"  📖 readaloud — {cwd}"[:W-1], curses.color_pair(8)|curses.A_BOLD)
            stdscr.addstr(1, 0, "─"*(W-1), curses.color_pair(2))
        except curses.error: pass
        vis = H-5
        if sel < scroll: scroll = sel
        elif sel >= scroll+vis: scroll = sel-vis+1
        for row in range(vis):
            idx = scroll+row
            if idx >= len(elist): break
            name, is_dir, _ = elist[idx]
            pre  = "📁 " if is_dir else "📄 "
            line = f"  {pre}{name}"
            attr = (curses.color_pair(3)|curses.A_BOLD if idx==sel
                    else curses.color_pair(2) if is_dir
                    else curses.color_pair(1))
            try:
                stdscr.addstr(2+row, 0,
                    line[:W-1].ljust(W-1) if idx==sel else line[:W-1], attr)
            except curses.error: pass
        try:
            stdscr.addstr(H-2, 0, "  ↑↓:nav  Enter:open  q:quit"[:W-1], curses.color_pair(2))
        except curses.error: pass
        stdscr.refresh()
        k = stdscr.getch()
        if k == ord('q'): return None
        elif k == curses.KEY_UP:   sel = max(0, sel-1)
        elif k == curses.KEY_DOWN: sel = min(len(elist)-1, sel+1)
        elif k in (curses.KEY_ENTER, 10, 13) and elist:
            name, is_dir, path = elist[sel]
            if is_dir: cwd=path; elist=entries(cwd); sel=scroll=0
            else: return str(path)

# ─── Main ─────────────────────────────────────────────────────────────────────

def main():
    check_deps()
    cfg = load_config()

    start_debug = "--debug" in sys.argv
    args = [a for a in sys.argv[1:] if not a.startswith("--")]

    if args:
        filepath = args[0]
    else:
        filepath = curses.wrapper(pick_file)
        if not filepath:
            print("No file selected."); sys.exit(0)

    if not os.path.exists(filepath):
        print(f"File not found: {filepath}"); sys.exit(1)

    ext = Path(filepath).suffix.lower()
    print(f"Parsing {Path(filepath).name}…", end="", flush=True)
    try:
        if ext == ".epub":   chapters = parse_epub(filepath)
        elif ext == ".txt":  chapters = parse_txt(filepath)
        else: print(f"\nUnsupported: {ext}"); sys.exit(1)
    except Exception as e:
        print(f"\nParse error: {e}")
        log.exception("parse error")
        sys.exit(1)

    if not chapters:
        print("\nNo readable chapters found."); sys.exit(1)
    print(f" {len(chapters)} chapters.")
    cfg["last_file"] = filepath
    save_config(cfg)
    log.info("starting TUI: %s  %d chapters  debug=%s", filepath, len(chapters), start_debug)

    def _run(s):
        TUI(s, chapters, filepath, cfg, start_debug=start_debug).run()

    curses.wrapper(_run)

if __name__ == "__main__":
    main()
